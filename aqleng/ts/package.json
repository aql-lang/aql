{
  "name": "@voxgig/aqleng",
  "version": "0.1.0",
  "description": "TypeScript port of the AQL execution engine. Pure engine — no parser, no built-in word library.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:spec": "vitest run spec.test.ts"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "@types/node": "^22.10.0"
  },
  "files": [
    "dist",
    "src"
  ]
}
