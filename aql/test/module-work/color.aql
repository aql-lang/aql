fn [[s:String] [Integer] [
  s convert Integer {base:"hex"}
]] def hex2int ;

fn [[n:Integer] [String] [
  n convert String {base:"hex"} pad 2 {side:"left" fill:"0"} upper
]] def int2hex ;

fn [[hex:String] [Map] [
  (hex slice 1 3 hex2int) def rv ;
  (hex slice 3 5 hex2int) def gv ;
  (hex slice 5 7 hex2int) def bv ;
  do {r:[rv] g:[gv] b:[bv]}
]] def hex2rgb ;

fn [[rgb:Map] [String] [
  "#" add (rgb r dot int2hex) add (rgb g dot int2hex) add (rgb b dot int2hex)
]] def rgb2hex ;

fn [[n:Integer] [Integer] [
  (n lt 0) [0] [(n gt 255) [255] [n] if] if
]] def clamp ;

fn [[rgb:Map] [Map] [
  do {r:[rgb r dot clamp] g:[rgb g dot clamp] b:[rgb b dot clamp]}
]] def clamp-rgb ;

fn [[hex:String] [Map] [
  (hex slice 1 3 hex2int) def rv ;
  (hex slice 3 5 hex2int) def gv ;
  (hex slice 5 7 hex2int) def bv ;
  do {hex:[hex] r:[rv] g:[gv] b:[bv]}
]] def make-color ;

export Color {
  hex2rgb:    hex2rgb
  rgb2hex:    rgb2hex
  hex2int:    hex2int
  int2hex:    int2hex
  clamp:      clamp
  clamp-rgb:  clamp-rgb
  make-color: make-color
}
