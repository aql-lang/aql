def hex2int fn [[String] [Integer] [
  convert Integer {base:"hex"}
]]

def int2hex fn [[Integer] [String] [
  convert String {base:"hex"} pad 2 {side:"left" fill:"0"} upper
]]

def hex2rgb fn [[hex:String] [Map] [
  def rv (hex slice 1 3 hex2int)
  def gv (hex slice 3 5 hex2int)
  def bv (hex slice 5 7 hex2int)
  do {r:[rv] g:[gv] b:[bv]}
]]

def rgb2hex fn [[rgb:Map] [String] [
  "#" add (rgb r dot int2hex) add (rgb g dot int2hex) add (rgb b dot int2hex)
]]

def clamp fn [[n:Integer] [Integer] [
  (n lt 0) [0] [(n gt 255) [255] [n] if] if
]]

def clamp-rgb fn [[rgb:Map] [Map] [
  do {r:[rgb r dot clamp] g:[rgb g dot clamp] b:[rgb b dot clamp]}
]]

def make-color fn [[hex:String] [Map] [
  def rv (hex slice 1 3 hex2int)
  def gv (hex slice 3 5 hex2int)
  def bv (hex slice 5 7 hex2int)
  do {hex:[hex] r:[rv] g:[gv] b:[bv]}
]]

export Color {
  hex2rgb:    hex2rgb
  rgb2hex:    rgb2hex
  hex2int:    hex2int
  int2hex:    int2hex
  clamp:      clamp
  clamp-rgb:  clamp-rgb
  make-color: make-color
}
