(import "../color")

def accent1 (color.make-color "#E63946")
def light1 (color.make-color "#F1FAEE")
def mid1 (color.make-color "#A8DADC")
def dark1 (color.make-color "#457B9D")
def deep1 (color.make-color "#1D3557")

def earth1 (color.make-color "#264653")
def earth2 (color.make-color "#2A9D8F")
def earth3 (color.make-color "#E9C46A")
def earth4 (color.make-color "#F4A261")
def earth5 (color.make-color "#E76F51")

def neon1 (color.make-color "#FF006E")
def neon2 (color.make-color "#FB5607")
def neon3 (color.make-color "#FFBE0B")
def neon4 (color.make-color "#8338EC")
def neon5 (color.make-color "#3A86FF")

def sunset {
  name: "sunset"
  primary: accent1
  secondary: light1
  accent: mid1
  dark: dark1
  background: deep1
}

def ocean {
  name: "ocean"
  primary: earth1
  secondary: earth2
  accent: earth3
  dark: earth4
  background: earth5
}

def neon {
  name: "neon"
  primary: neon1
  secondary: neon2
  accent: neon3
  dark: neon4
  background: neon5
}

export Schemes {
  sunset: sunset
  ocean: ocean
  neon: neon
}
