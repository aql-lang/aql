(import "../color")

def accent1 ("#E63946" Color.make-color)
def light1 ("#F1FAEE" Color.make-color)
def mid1 ("#A8DADC" Color.make-color)
def dark1 ("#457B9D" Color.make-color)
def deep1 ("#1D3557" Color.make-color)

def earth1 ("#264653" Color.make-color)
def earth2 ("#2A9D8F" Color.make-color)
def earth3 ("#E9C46A" Color.make-color)
def earth4 ("#F4A261" Color.make-color)
def earth5 ("#E76F51" Color.make-color)

def neon1 ("#FF006E" Color.make-color)
def neon2 ("#FB5607" Color.make-color)
def neon3 ("#FFBE0B" Color.make-color)
def neon4 ("#8338EC" Color.make-color)
def neon5 ("#3A86FF" Color.make-color)

def sunset do {
  name: "sunset"
  primary: accent1
  secondary: light1
  accent: mid1
  dark: dark1
  background: deep1
}

def ocean do {
  name: "ocean"
  primary: earth1
  secondary: earth2
  accent: earth3
  dark: earth4
  background: earth5
}

def neon do {
  name: "neon"
  primary: neon1
  secondary: neon2
  accent: neon3
  dark: neon4
  background: neon5
}

export Schemes {
  sunset: sunset
  ocean: ocean
  neon: neon
}
