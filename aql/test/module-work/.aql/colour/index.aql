def hex2int fn [[s:String] [Integer] [
  s Integer {base:"hex"} convert
]] end

def int2hex fn [[n:Integer] [String] [
  n convert String {base:"hex"} 2 {side:"left" fill:"0"} pad upper
]] end

def hex2rgb fn [[hex:String] [Map] [
  hex 1 3 slice hex2int def rv end
  hex 3 5 slice hex2int def gv end
  hex 5 7 slice hex2int def bv end
  do {r:[rv] g:[gv] b:[bv]}
]] end

def rgb2hex fn [[rgb:Map] [String] [
  "#" rgb r dot int2hex add rgb g dot int2hex add rgb b dot int2hex add
]] end

def clamp fn [[n:Integer] [Integer] [
  (n lt 0) [0] [(n gt 255) [255] [n] if] if
]] end

def make-colour fn [[hex:String] [Map] [
  hex 1 3 slice hex2int def rv end
  hex 3 5 slice hex2int def gv end
  hex 5 7 slice hex2int def bv end
  do {hex:[hex] r:[rv] g:[gv] b:[bv]}
]] end

"#FF0000" make-colour def red end
"#00FF00" make-colour def green end
"#0000FF" make-colour def blue end
"#FFFF00" make-colour def yellow end
"#FF8000" make-colour def orange end
"#800080" make-colour def purple end
"#00FFFF" make-colour def cyan end
"#FFFFFF" make-colour def white end
"#000000" make-colour def black end
"#808080" make-colour def grey end

export Colour {
  red: red
  green: green
  blue: blue
  yellow: yellow
  orange: orange
  purple: purple
  cyan: cyan
  white: white
  black: black
  grey: grey
}
