type RGB record [r:Integer g:Integer b:Integer]

def hex2int fn [[String] [Integer] [
  convert Integer {base:"hex"}
]]

def int2hex fn [[Integer] [String] [
  convert String {base:"hex"} pad 2 {side:"left" fill:"0"} upper
]]

def hex2rgb fn [[hex:String] [Map] [
  def rv (hex slice 1 3 hex2int)
  def gv (hex slice 3 5 hex2int)
  def bv (hex slice 5 7 hex2int)
  {r:rv g:gv b:bv}
]]

def rgb2hex fn [[rgb:RGB] [String] [
  "#" add (int2hex (rgb.r)) add (int2hex (rgb.g)) add (int2hex (rgb.b))
]]

def clamp fn [[n:Integer] [Integer] [
  if (n lt 0) [0] [if (n gt 255) [255] [n]]
]]

def clamp-rgb fn [[rgb:RGB] [Map] [
  {r:(rgb.r clamp) g:(rgb.g clamp) b:(rgb.b clamp)}
]]

def make-color fn [[hex:String] [Map] [
  def rv (hex slice 1 3 hex2int)
  def gv (hex slice 3 5 hex2int)
  def bv (hex slice 5 7 hex2int)
  {hex:hex r:rv g:gv b:bv}
]]

export Color {
  RGB:        RGB
  hex2rgb:    hex2rgb
  rgb2hex:    rgb2hex
  hex2int:    hex2int
  int2hex:    int2hex
  clamp:      clamp
  clamp-rgb:  clamp-rgb
  make-color: make-color
}
