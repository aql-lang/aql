=== BEHAVIOR ===
CASE add-forward
  add 2 3
  => "5"
CASE sub-swap
  10 sub 3
  => "7"
CASE sub-forward
  sub 10 3
  => "-7"
CASE mul-stack
  4 5 mul
  => "20"
CASE nested-arith
  add (mul 2 3) (sub 10 4)
  => "0"
CASE if-then
  if true 99 88 end
  => "99"
CASE if-else
  if false 99 88 end
  => "88"
CASE if-listcond-then
  if [1 gt 0] 99 88 end
  => "99"
CASE if-listcond-else
  if [1 lt 0] 99 88 end
  => "88"
CASE if-no-else-true
  if true 99 end
  => "99"
CASE if-no-else-false
  if false 99 end
  => ""
CASE if-clauselist
  if [false "a" true "b" "c"]
  => "'b'"
CASE if-bodyeval
  if true [1 add 2] [10 add 20] end
  => "3"
CASE named-fn-simple
  def dbl fn [[n:Integer] [Integer] [n mul 2]]  dbl 21
  => "42"
CASE named-fn-forward
  def f fn [[a:Integer b:Integer] [Integer] [a sub b]]  f 10 3
  => "7"
CASE named-fn-recursive
  def fact fn [[n:Integer] [Integer] [if (n lte 1) [1] [n mul (fact (n sub 1))]]]  fact 5
  => "120"
CASE named-fn-multi-overload
  def g fn [[a:Integer] [Integer] [a add 1] [a:String] [String] [a]]  g 41
  => "42"
CASE afn-direct
  ([n:Integer] => [n add 1]) 41
  => "42"
CASE closure-adder
  def make-adder ([x:Integer] => [([y:Integer] => [x add y])])  def add5 (make-adder 5)  add5 3
  => "8"
CASE closure-reuse
  def make-adder ([x:Integer] => [([y:Integer] => [x add y])])  def add5 (make-adder 5)  add5 3  add5 10
  => "8 15"
CASE each-double
  [1 2 3] each [dup add]
  => "[2 4 6]"
CASE fold-sum
  [1 2 3 4] 0 fold [add]
  => "RUNERR: [aql/signature_error]: no matching signature for fold\n  --> 1:13\n  = expected: fold (List, List, Any) or (List, List)\n  = forward args for fold may have run into the next word; group the call with parens — (fold …) — or end it with `end` or `;`\n  = stack: List 0 >>>word(fold)<<< List"
CASE math-max-bound
  def m import "aql:math"  m.max 3 7
  => "RUNERR: [aql/undefined_word]: undefined word: m\n  --> 1:26"
CASE math-max-inscope
  import "aql:math"  max 3 7
  => "RUNERR: import: native module resolver not configured (cannot import \"aql:math\")"
CASE array-len
  def a import "aql:array"  a.length [10 20 30]
  => "RUNERR: [aql/undefined_word]: undefined word: a\n  --> 1:27"
CASE dup
  5 dup add
  => "10"
CASE swap
  1 2 swap sub
  => "1"
CASE drop
  1 2 3 drop
  => "1 2"
